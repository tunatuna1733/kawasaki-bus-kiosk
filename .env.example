# Base URL of the Kawasaki GTFS API server (https://github.com/tunatuna1733/kawasaki-gtfs-api)
# No trailing slash. Example for a local instance:
GTFS_API_BASE=http://localhost:8080

# Port this kiosk server listens on (optional, default 3000)
PORT=3000

# Path to the persisted dashboard config (optional, default ./config.json)
# CONFIG_PATH=./config.json
